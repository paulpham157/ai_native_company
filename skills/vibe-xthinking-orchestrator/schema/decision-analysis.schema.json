{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "decision-analysis.schema.json",
  "title": "Decision Analysis",
  "description": "Output of MODE DECISION — single-agent decision matrix analysis.",
  "type": "object",
  "required": ["analysis_id", "decision", "mode", "framework", "options", "evidence", "confidence_score", "need_review"],
  "properties": {
    "analysis_id": {"type": "string"},
    "decision": {"type": "string"},
    "mode": {"type": "string", "enum": ["decision"]},
    "framework": {"type": "string", "enum": ["eisenhower", "rice", "decision-matrix"]},
    "options": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "scores"],
        "properties": {
          "name": {"type": "string"},
          "scores": {
            "type": "object",
            "patternProperties": {
              "^[a-z_]+$": {"type": "number"}
            }
          },
          "total": {"type": "number"}
        }
      }
    },
    "recommendation": {"type": "string"},
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "claim": {"type": "string"},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1},
          "source": {"type": "string"}
        }
      }
    },
    "confidence_score": {"type": "number", "minimum": 0, "maximum": 1},
    "need_review": {"type": "boolean"}
  }
}