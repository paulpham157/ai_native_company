{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "explicit-thinking.schema.json",
  "title": "Explicit Thinking Outline",
  "description": "Common schema cho explicit thinking outline used by Agent 2 in MODE TOPIC.",
  "type": "object",
  "required": ["thinking_id", "analysis_ref", "assumptions", "logic_chain", "gaps", "evidence", "confidence_score", "need_review"],
  "properties": {
    "thinking_id": {"type": "string"},
    "analysis_ref": {"type": "string"},
    "assumptions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["assumption", "confidence"],
        "properties": {
          "assumption": {"type": "string"},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1},
          "challenge": {"type": "string"}
        }
      }
    },
    "logic_chain": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "step": {"type": "string"},
          "premise": {"type": "string"},
          "conclusion": {"type": "string"}
        }
      }
    },
    "gaps": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "gap": {"type": "string"},
          "severity": {"type": "string", "enum": ["low", "medium", "high"]}
        }
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "claim": {"type": "string"},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1},
          "source": {"type": "string"}
        }
      }
    },
    "confidence_score": {"type": "number", "minimum": 0, "maximum": 1},
    "need_review": {"type": "boolean"}
  }
}