{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "evidence-tracking.schema.json",
  "title": "Evidence Tracking",
  "description": "Common schema cho evidence/confidence tracking across all analysis modes.",
  "type": "object",
  "required": ["tracking_id", "analysis_ref", "evidence_chain", "aggregate_confidence", "need_review"],
  "properties": {
    "tracking_id": {"type": "string"},
    "analysis_ref": {"type": "string"},
    "evidence_chain": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "agent": {"type": "string"},
          "claim": {"type": "string"},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1},
          "source": {"type": "string"}
        }
      }
    },
    "aggregate_confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "claim": {"type": "string"},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1},
          "source": {"type": "string"}
        }
      }
    },
    "confidence_score": {"type": "number", "minimum": 0, "maximum": 1},
    "need_review": {"type": "boolean"}
  }
}