{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "problem-analysis.schema.json",
  "title": "Problem Analysis",
  "description": "Output of MODE PROBLEM — single-agent root cause analysis using systematic frameworks.",
  "type": "object",
  "required": ["analysis_id", "problem", "mode", "framework", "root_causes", "evidence", "confidence_score", "need_review"],
  "properties": {
    "analysis_id": {"type": "string"},
    "problem": {"type": "string"},
    "mode": {"type": "string", "enum": ["problem"]},
    "framework": {"type": "string", "enum": ["5-whys", "fishbone", "rca"]},
    "root_causes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["cause", "level"],
        "properties": {
          "cause": {"type": "string"},
          "level": {"type": "integer", "minimum": 1},
          "category": {"type": "string"}
        }
      }
    },
    "recommendations": {
      "type": "array",
      "items": {"type": "string"}
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "claim": {"type": "string"},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1},
          "source": {"type": "string"}
        }
      }
    },
    "confidence_score": {"type": "number", "minimum": 0, "maximum": 1},
    "need_review": {"type": "boolean"}
  }
}