{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "topic-analysis.schema.json",
  "title": "Topic Analysis",
  "description": "Output of MODE TOPIC — multi-agent analysis result for industry/domain topics.",
  "type": "object",
  "required": ["analysis_id", "topic", "mode", "phases", "evidence", "confidence_score", "need_review"],
  "properties": {
    "analysis_id": {"type": "string"},
    "topic": {"type": "string"},
    "mode": {"type": "string", "enum": ["topic"]},
    "phases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["phase", "agent", "output"],
        "properties": {
          "phase": {"type": "string", "enum": ["research", "thinking", "synthesis", "validation"]},
          "agent": {"type": "string"},
          "output": {"type": "object"}
        }
      }
    },
    "insights": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "claim": {"type": "string"},
          "evidence": {"type": "string"},
          "source": {"type": "string"}
        }
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "claim": {"type": "string"},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1},
          "source": {"type": "string"}
        }
      }
    },
    "confidence_score": {"type": "number", "minimum": 0, "maximum": 1},
    "need_review": {"type": "boolean"}
  }
}