{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "quality-rubric.schema.json",
  "title": "Quality Rubric",
  "description": "Rubric đánh giá chất lượng artifact — clarity, completeness, accuracy.",
  "type": "object",
  "required": ["rubric_id", "artifact_type", "dimensions"],
  "properties": {
    "rubric_id": {
      "type": "string",
      "description": "Unique identifier cho rubric"
    },
    "artifact_type": {
      "type": "string",
      "enum": ["markdown", "json", "yaml"],
      "description": "Loại artifact mà rubric này áp dụng"
    },
    "dimensions": {
      "type": "array",
      "description": "Các dimension đánh giá chất lượng",
      "items": {
        "type": "object",
        "required": ["name", "weight", "criteria"],
        "properties": {
          "name": {
            "type": "string",
            "enum": ["clarity", "completeness", "accuracy", "consistency", "actionability"]
          },
          "weight": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "Weight của dimension trong tổng điểm (sum = 1)"
          },
          "criteria": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["level", "description"],
              "properties": {
                "level": {
                  "type": "string",
                  "enum": ["excellent", "good", "needs_improvement", "poor"]
                },
                "description": {
                  "type": "string",
                  "description": "Mô tả tiêu chí ở level này"
                }
              }
            },
            "minItems": 1
          }
        }
      },
      "minItems": 1
    }
  }
}
